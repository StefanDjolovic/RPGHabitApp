{
  "expo": {
    "name": "Habit RPG",
    "slug": "habit-rpg",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b3a64e61-ed77-468c-ba70-95ec6b97fafd"
    },
    "orientation": "portrait",
    "icon": "./assets/images/habit-rpg-icon.png",
    "scheme": "habitrpg",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.stefan.habitrpg",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#070912",
        "foregroundImage": "./assets/images/habit-rpg-android-foreground.png",
        "backgroundImage": "./assets/images/habit-rpg-android-background.png",
        "monochromeImage": "./assets/images/habit-rpg-android-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/habit-rpg-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/habit-rpg-splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#070912",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#6DDEFF",
          "defaultChannel": "habit-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3a64e61-ed77-468c-ba70-95ec6b97fafd"
      }
    }
  }
}
